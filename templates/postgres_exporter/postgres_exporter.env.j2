# /etc/default/postgres_exporter — by Ansible，请勿手工修改。
# 改动入口：control 机 ~/.pginstall/secrets.env 的 MONITOR_PASSWORD，重跑
# script/install_postgres_exporter.yml 即可同步覆盖。
#
# 走 libpq kv 形式而非 URI，免去密码 URL 编码；systemd EnvironmentFile 用
# 双引号括住整段值即可承载空格分隔的 kv 串。
DATA_SOURCE_NAME="host=127.0.0.1 port=5432 user=dbuser_monitor password={{ monitor_password }} dbname=postgres sslmode=disable"
