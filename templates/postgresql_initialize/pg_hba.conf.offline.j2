{% set allowed_client_cidrs = pg_allowed_client_cidrs | default(['10.0.0.0/8', '172.0.0.0/8']) %}
#管理账号
local   all   postgres       peer

#127.0.0.1(允许系统用户通过本机 PostgreSQL / PgBouncer 验证登录)
host   all   +dbrole_sa                    127.0.0.1/32     scram-sha-256
host   all   +dbrole_readonly              127.0.0.1/32     scram-sha-256
host   all   +dbrole_readwrite             127.0.0.1/32     scram-sha-256
host   all   +dbrole_readwrite_with_delete 127.0.0.1/32     scram-sha-256
host   all   +dbrole_offline               127.0.0.1/32     scram-sha-256
host   replication  replication            127.0.0.1/32     scram-sha-256

#统一放通 DBA、业务、offline 和复制账号的客户端网段
{% for cidr in allowed_client_cidrs %}
host   all          +dbrole_sa                    {{ cidr }}     scram-sha-256
host   all          +dbrole_readonly              {{ cidr }}     scram-sha-256
host   all          +dbrole_readwrite             {{ cidr }}     scram-sha-256
host   all          +dbrole_readwrite_with_delete {{ cidr }}     scram-sha-256
host   all          +dbrole_offline               {{ cidr }}     scram-sha-256
host   replication  replication                   {{ cidr }}     scram-sha-256
{% endfor %}

#########以上部分为配置标准，每台PG实例都应这样配置#########
