#管理账号
local   all   postgres       ident
host    all   +dbrole_sa     10.9.50.127/32        md5
host    all   +dbrole_sa     10.179.10.102/32      md5
host    all   +dbrole_sa     10.179.3.240/32       md5
#127.0.0.1(允许监控用户和系统用户通过PGB访问)
host   all   dbuser_monitor                  127.0.0.1/32     md5
host   all   +dbrole_readonly                127.0.0.1/32     md5
host   all   +dbrole_readwrite               127.0.0.1/32     md5
host   all   +dbrole_readwrite_with_delete   127.0.0.1/32     md5
 
 
host   all   +dbrole_readwrite_with_delete   10.189.0.0/16    md5
host   all   +dbrole_readwrite_with_delete   10.179.0.0/16     md5
 
#replication(允许本地备份复制和standby复制)
host replication  replication    127.0.0.1/32        md5
host replication  replication    10.189.0.0/16       md5
#########以上部分为配置标准，每台PG实例都应这样配置#########
#为测试添加的的ip段
host replication  replication    10.9.0.0/16       md5
 
#########以下部分按照不同的PG实例角色来配置#########
#(master实例，拒绝offline组访问)
host   all    +dbrole_offline     0.0.0.0/0     reject
